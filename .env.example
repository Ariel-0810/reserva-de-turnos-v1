# ==============================================
# 🗄️ DATABASE CONFIGURATION (REQUERIDO)
# ==============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?options
# 
# Para desarrollo local:
# DATABASE_URL='postgresql://usuario:contraseña@localhost:5432/booking_saas'
#
# Para Neon.tech (recomendado para producción):
# DATABASE_URL='postgresql://user:password@host.neon.tech/dbname?sslmode=require'
#
DATABASE_URL='postgresql://usuario:contraseña@localhost:5432/booking_saas?sslmode=require'

# ==============================================
# 🔐 NEXTAUTH CONFIGURATION (REQUERIDO)
# ==============================================
# Base URL of your application
# Desarrollo: http://localhost:3000
# Producción: https://tu-dominio.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Secret key for NextAuth (generate a random string)
# ⚠️ IMPORTANTE: Genera uno nuevo para producción
# Comando: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ==============================================
# 📧 EMAIL CONFIGURATION (REQUERIDO)
# ==============================================
# Get your API key from https://resend.com
# Necesario para enviar emails de verificación y recuperación de contraseña
RESEND_API_KEY="re_your_api_key_here"

# ==============================================
# 🔑 GOOGLE OAUTH (Opcional)
# ==============================================
# Get credentials from: https://console.cloud.google.com
# Solo necesario si quieres permitir login con Google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==============================================
# 💬 TWILIO WHATSAPP (Opcional)
# ==============================================
# Get credentials from: https://console.twilio.com
# Solo necesario si quieres enviar notificaciones por WhatsApp
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# ==============================================
# 👨‍💼 SUPERADMIN NOTIFICATIONS (Opcional)
# ==============================================
# Email address to receive notifications about new business registrations
SUPERADMIN_EMAIL="your-admin-email@example.com"

# ==============================================
# 📝 NOTAS IMPORTANTES
# ==============================================
# 1. NUNCA subas este archivo con valores reales a GitHub
# 2. Copia este archivo a .env y actualiza los valores
# 3. Para Vercel, configura estas variables en Settings → Environment Variables
# 4. Las variables marcadas como REQUERIDAS son necesarias para que la app funcione
# 5. Las variables opcionales solo se necesitan si usas esas features
