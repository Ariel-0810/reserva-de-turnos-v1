# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?options
DATABASE_URL='postgresql://usuario:contraseña@localhost:5432/booking_saas?sslmode=require'

# ==============================================
# NEXTAUTH CONFIGURATION
# ==============================================
# Base URL of your application
NEXTAUTH_URL=http://localhost:3000

# Secret key for NextAuth (generate a random string)
# You can generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ==============================================
# EMAIL CONFIGURATION (Resend)
# ==============================================
# Get your API key from https://resend.com
RESEND_API_KEY="re_your_api_key_here"

# ==============================================
# GOOGLE OAUTH (Optional)
# ==============================================
# Get credentials from: https://console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==============================================
# TWILIO WHATSAPP (Optional)
# ==============================================
# Get credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# ==============================================
# SUPERADMIN NOTIFICATIONS
# ==============================================
# Email address to receive notifications about new business registrations
SUPERADMIN_EMAIL="your-admin-email@example.com"
